---
import BaseLayout from "@layouts/BaseLayout.astro";
import { SITE } from "@data/site";
import { materials } from "@data/materials";
import { categories } from "@data/products";

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}/images/logo.png`,
  description:
    "Piercova offers implant-grade body piercing jewelry manufactured to ASTM F136 titanium, ASTM F138 surgical steel, 925 sterling silver, and 14K solid gold standards. Based in Yiwu, China. Shop earrings, belly rings, nose rings, lip rings, and nipple rings.",
  email: SITE.email,
  foundingDate: "2020",
  sameAs: [
    SITE.social.instagram,
    SITE.social.pinterest,
    SITE.social.tiktok,
  ],
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.name,
  url: SITE.url,
  description:
    "Implant-grade body piercing jewelry — ASTM F136 Titanium, ASTM F138 Surgical Steel, 925 Sterling Silver, 14K Gold. Shop by category or material.",
  potentialAction: {
    "@type": "SearchAction",
    target: {
      "@type": "EntryPoint",
      urlTemplate: `${SITE.url}/search?q={search_term_string}`,
    },
    "query-input": "required name=search_term_string",
  },
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Piercova",
      item: SITE.url,
    },
  ],
};
---

<BaseLayout
  title="Implant-Grade Body Piercing Jewelry"
  description="Piercova — implant-grade body piercing jewelry. ASTM F136 Titanium, ASTM F138 Surgical Steel, 925 Sterling Silver, 14K Solid Gold. Shop earrings, belly rings, nose rings, lip rings, and nipple rings."
  jsonld={[orgSchema, webSiteSchema, breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <h1>{SITE.tagline}</h1>
      <p class="hero-lead">
        Every piece manufactured to ASTM standards. Titanium. Surgical Steel.
        Sterling Silver. 14K Gold. Designed for your body, engineered for life.
      </p>
      <div class="hero-actions">
        <a href="#categories" class="btn-primary">Shop by Category</a>
        <a href="#materials" class="btn-secondary">Materials Guide</a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section id="categories" class="section">
    <div class="container">
      <div class="section-title">
        <h2>Shop by Category</h2>
        <p>Implant-grade jewelry for every piercing location</p>
      </div>
      <div class="category-grid">
        {categories.map((cat) => (
          <a href={`/categories/${cat.slug}`} class="category-card">
            <h3>{cat.name}</h3>
            <p>{cat.description}</p>
            <span class="card-arrow">Browse &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Materials -->
  <section id="materials" class="section section-alt">
    <div class="container">
      <div class="section-title">
        <h2>Materials Guide</h2>
        <p>Understanding the science behind implant-grade materials</p>
      </div>
      <div class="material-grid">
        {materials.map((m) => (
          <div class="material-card">
            <div class="material-badge">
              {m.hypoallergenic ? "✓ Nickel-Free" : "Contains Nickel"}
            </div>
            <h3>{m.name}</h3>
            <p class="material-standard">{m.standard}</p>
            <p class="material-desc">{m.subtitle}</p>
            <a href={`/materials/${m.slug}`} class="card-arrow">
              Full guide &rarr;
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Trust -->
  <section class="section trust-section">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item">
          <h3>ASTM Certified</h3>
          <p>All materials verified to ASTM International standards — F136 for titanium, F138 for surgical steel.</p>
        </div>
        <div class="trust-item">
          <h3>Implant-Grade</h3>
          <p>The same materials used in surgical implants. Biocompatible, corrosion-resistant, safe for long-term wear.</p>
        </div>
        <div class="trust-item">
          <h3>Nickel-Free Options</h3>
          <p>Titanium, gold, and sterling silver are 100% nickel-free. Safe for allergy sufferers.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    text-align: center;
    background: linear-gradient(180deg, #0a0a0a 0%, var(--color-bg) 100%);
  }
  .hero h1 {
    font-size: 3rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }
  .hero-lead {
    font-size: 1.125rem;
    color: var(--color-text-dim);
    max-width: 680px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn-primary,
  .btn-secondary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.15s;
  }
  .btn-primary {
    background: var(--color-accent);
    color: #0a0a0a;
  }
  .btn-primary:hover {
    background: var(--color-accent-dim);
    color: #0a0a0a;
  }
  .btn-secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }
  .btn-secondary:hover {
    border-color: #444;
    background: var(--color-surface);
  }

  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .category-card {
    display: block;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .category-card:hover {
    border-color: #444;
    transform: translateY(-2px);
  }
  .category-card h3 {
    color: #fff;
    font-size: 1rem;
    margin: 0 0 0.5rem;
  }
  .category-card p {
    color: var(--color-text-dim);
    font-size: 0.8125rem;
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }
  .card-arrow {
    color: var(--color-accent);
    font-size: 0.8125rem;
    font-weight: 500;
  }

  .section-alt {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }
  .material-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  .material-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 1.5rem;
    position: relative;
  }
  .material-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
  .material-card:nth-child(1) .material-badge,
  .material-card:nth-child(3) .material-badge,
  .material-card:nth-child(4) .material-badge {
    background: #1a3a1a;
    color: #4ade80;
  }
  .material-card:nth-child(2) .material-badge {
    background: #3a2a1a;
    color: #fbbf24;
  }
  .material-card h3 {
    font-size: 1.125rem;
    margin: 0 0 0.25rem;
  }
  .material-standard {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-dim);
    margin: 0 0 0.75rem;
  }
  .material-desc {
    font-size: 0.875rem;
    color: var(--color-text);
    margin: 0 0 1rem;
    line-height: 1.6;
  }

  .trust-section {
    padding: 4rem 0;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  .trust-item h3 {
    font-size: 1rem;
    margin: 0 0 0.5rem;
  }
  .trust-item p {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .hero h1 { font-size: 2rem; }
    .category-grid { grid-template-columns: 1fr 1fr; }
    .material-grid { grid-template-columns: 1fr; }
    .trust-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .category-grid { grid-template-columns: 1fr; }
  }
</style>
