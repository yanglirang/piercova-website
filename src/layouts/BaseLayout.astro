---
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import SEO, { type SEOProps } from "@components/SEO.astro";

type Props = SEOProps;

const { title, description, ogImage, ogType, canonical, noindex, jsonld } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonical={canonical}
      noindex={noindex}
      jsonld={jsonld}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #0d0d0d;
    --color-surface: #141414;
    --color-border: #1f1f1f;
    --color-text: #e0e0e0;
    --color-text-dim: #888;
    --color-accent: #c9a87c;
    --color-accent-dim: #a68a5c;
    --font-mono: "SF Mono", "Fira Code", "Fira Mono", "Roboto Mono", monospace;
    --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    margin: 0;
    padding: 0;
    background: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.7;
  }

  main {
    min-height: 60vh;
  }

  a {
    color: var(--color-accent);
    text-decoration: none;
  }
  a:hover {
    color: var(--color-accent-dim);
  }

  h1, h2, h3, h4, h5, h6 {
    color: #fff;
    line-height: 1.3;
  }
  h1 { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.02em; }
  h2 { font-size: 1.75rem; font-weight: 600; letter-spacing: -0.01em; }
  h3 { font-size: 1.25rem; font-weight: 600; }

  p { margin: 0 0 1rem; }

  ul, ol { padding-left: 1.5rem; margin: 0 0 1rem; }
  li { margin-bottom: 0.375rem; }

  code {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .page-hero {
    padding: 4rem 0 2rem;
    text-align: center;
  }
  .page-hero h1 {
    margin: 0 0 1rem;
  }
  .page-hero p {
    color: var(--color-text-dim);
    font-size: 1.125rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .section {
    padding: 3rem 0;
  }
  .section-title {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .section-title h2 {
    margin: 0 0 0.75rem;
  }
  .section-title p {
    color: var(--color-text-dim);
    max-width: 640px;
    margin: 0 auto;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  @media (max-width: 768px) {
    h1 { font-size: 1.75rem; }
    h2 { font-size: 1.375rem; }
    .page-hero { padding: 2rem 0 1.5rem; }
    .section { padding: 2rem 0; }
  }
</style>
